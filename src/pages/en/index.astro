---
const phone = "+34 822 145 513";
const phoneHref = "tel:+34822145513";
const whatsappHref = "https://wa.me/34646743707?text=Hello%2C%20I%20would%20like%20information%20about%20MAPFRE%20insurance.";

const products = [
  { title: "Car", text: "Protection for your vehicle.", icon: "/icons/car.svg" },
  { title: "Home", text: "Your home always protected.", icon: "/icons/home.svg" },
  { title: "Health", text: "Access to private healthcare.", icon: "/icons/health.svg" },
  { title: "Life", text: "Peace of mind for your family.", icon: "/icons/heart.svg" },
  { title: "Savings and investment", text: "Solutions for your future.", icon: "/icons/chart.svg" },
  { title: "Boats", text: "Sail with peace of mind.", icon: "/icons/boat.svg" },
  { title: "Business", text: "Insurance for companies and self-employed professionals.", icon: "/icons/building.svg" },
  { title: "Funeral insurance", text: "Everything organised for your family.", icon: "/icons/shield.svg" },
];

const languages = [
  { flag: "/flags/gb.svg", label: "English", href: "/en/" },
  { flag: "/flags/de.svg", label: "Deutsch", href: "/de/" },
  { flag: "/flags/it.svg", label: "Italiano", href: "/it/" },
  { flag: "/flags/fr.svg", label: "Français", href: "/fr/" },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>MAPFRE Adeje Office | Insurance in Tenerife</title>
  <link rel="icon" href="/logos/mapfre.svg" type="image/svg+xml" />
  <meta
    name="description"
    content="MAPFRE Adeje Office. Insurance in Tenerife for families, residents, self-employed professionals, shops and businesses."
  />
</head>

<body>
<header class="siteHeader">
  <a href="/" class="brand" aria-label="MAPFRE Adeje">
    <span class="logoFrame">
      <img src="/logos/mapfre.svg" alt="MAPFRE" />
    </span>
    <span class="brandText">
      <small>TENERIFE</small>
      MAPFRE Office ADEJE CALLE GRANDE
    </span>
  </a>
  <nav class="languageSwitcher">
    <a href="/">ES</a>
    <a href="/en/" class="active">EN</a>
    <a href="/de/">DE</a>
    <a href="/it/">IT</a>
    <a href="/fr/">FR</a>
  </nav>
  <nav class="headerActions">
    <a href={phoneHref} class="button cta">Call {phone}</a>
    <a href={whatsappHref} class="button secondary">WhatsApp</a>
  </nav>
</header>

<main>
  <section class="hero">
    <div class="heroContent">
      <p class="eyebrow">Your MAPFRE office in Adeje</p>

      <h1>Your trusted MAPFRE office in Adeje</h1>

      <p class="lead">
        Personalised insurance advice and tailored solutions for families, residents, self-employed professionals, shops and businesses.
      </p>

      <div class="heroActions">
        <a href={phoneHref} class="button primary large">Call us now</a>
        <a href={whatsappHref} class="button secondary large">Message us on WhatsApp</a>
      </div>

      <div class="officeCard">
        <strong>MAPFRE Adeje Team</strong>
        <span>Antonio Soto Melchor · Office Delegate</span>
        <span>Maryery Vargas Moreno · Commercial Advisor</span>

        <strong>Address:</strong>
        <span>Calle Grande, 56. 38670 - Adeje</span>
        <span>Santa Cruz de Tenerife · In-person and multilingual service</span>

        <strong>Opening hours:</strong>
        <span>Mon - Thu 9:00 - 19:00</span>
        <span>Fri 9:00 - 17:00</span>

        <div class="mapa">
          <iframe
            src="https://www.google.com/maps?q=Calle+Grande+56+Adeje&output=embed"
            width="100%"
            height="350"
            style="border:0;border-radius:12px;"
            loading="lazy"
            allowfullscreen="">
          </iframe>

          <a
            href="https://maps.google.com/?q=Calle+Grande+56+Adeje"
            target="_blank"
            class="btnMapa">
            Get directions
          </a>
        </div>
      </div>
    </div>

    <div class="heroImage">
      <img src="/images/antonio.png" alt="Antonio Soto Melchor, MAPFRE Adeje office delegate" />
    </div>
  </section>

  <section class="products">
    <div class="sectionHeader">
      <p class="eyebrow">Our insurance products</p>
      <h2>Your trusted office for all your insurance needs</h2>
    </div>

    <div class="productGrid">
      {products.map((product) => (
        <article class="productCard">
          <img src={product.icon} alt={product.title} class="productIcon" />

          <h3>{product.title}</h3>

          <p>{product.text}</p>

          <a
            href={`https://wa.me/34646743707?text=${encodeURIComponent(
              `Hello, I would like information about ${product.title} insurance with MAPFRE Adeje - Calle Grande 56.`
            )}`}
            target="_blank"
            class="productLink"
          >
            Request a quote →
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="trust">
    <div>
      <p class="eyebrow">Experience and proximity</p>
      <h2>Advice with judgement, commitment and local knowledge</h2>
    </div>

    <p>
      We are not a comparison website or a call centre. We are a physical office in Adeje, where we provide personal advice to help you choose the insurance you really need. We analyse your situation, answer your questions and support you when you need us most.
    </p>
  </section>

  <section class="team">
    <div class="teamImage">
      <img src="/images/maryery.JPG" alt="Maryery Vargas Moreno, commercial advisor at MAPFRE Adeje" />
    </div>

    <div class="teamContent">
      <p class="eyebrow">Personalised service</p>
      <h2>Meet your MAPFRE Adeje team</h2>

      <p>
        We will assist you in a clear, friendly and professional way to help you find the insurance solution that best suits your needs.
      </p>

      <div class="teamCard">
        <strong>Maryery Vargas Moreno</strong>
        <span>Commercial Advisor · MAPFRE Adeje</span>
      </div>

      <div class="teamCard">
        <strong>Antonio Soto Melchor</strong>
        <span>Office Delegate · MAPFRE Adeje</span>
      </div>
    </div>
  </section>
  <section class="reviews">
  <div class="reviewsContent">
    <p class="eyebrow">Customer Reviews</p>

    <h2>The trust of our clients speaks for itself</h2>

    <div class="reviewStars">★★★★★</div>

    <p class="reviewText">
      Read what our clients say about the service, support and personalised advice provided by MAPFRE Adeje.
    </p>

    <a
      href="https://www.google.com/search?q=mapfre+adeje+calle+grande"
      target="_blank"
      rel="noopener noreferrer"
      class="reviewButton"
    >
      Read Google Reviews
    </a>
  </div>
</section>

  <section class="languages">
    <div class="languageContent">
      <div>
        <p class="eyebrow">Multilingual service</p>

        <h2>We assist foreign residents and property owners in Tenerife</h2>

        <p class="languageText">
          We help you arrange and manage your insurance in your language, with friendly and personalised service from our office in Adeje.
        </p>
      </div>

      <div class="languageGrid">
        {languages.map((language) => (
          <a href={language.href} class="languageCard">
            <span class="languageInfo">
              <img src={language.flag} alt={language.label} class="languageFlag" />
              <span>{language.label}</span>
            </span>
            <strong>→</strong>
          </a>
        ))}
      </div>
    </div>
  </section>
</main>
</body>
</html>

<style>
  :root {
    --red: #e30613;
    --red-dark: #c90012;
    --muted: #65707c;
    --bg: #f5f5f5;
    --white: #ffffff;
    --line: #e9e9e9;
    --radius-md: 22px;
    --black: #1f2937;
    --text: #4b5563;
    --heading: #202938;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: var(--bg);
    color: var(--black);
  }

  a {
    text-decoration: none;
  }

  .siteHeader {
    height: 84px;
    padding: 0 clamp(24px, 6vw, 88px);
    background: var(--white);
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
    color: var(--black);
    font-weight: 900;
  }

  .logoFrame {
    width: 132px;
    height: 100px;
    display: flex;
    align-items: center;
    overflow: hidden;
    flex: 0 0 auto;
    padding: 5px;
  }

  .logoFrame img {
    width: 132px;
    height: auto;
    display: block;
  }

  .brandText {
    border-left: 1px solid #e7e7e7;
    padding-left: 22px;
    margin-left: 6px;
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    white-space: nowrap;
  }

  .brandText small {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: #9aa3af;
    font-weight: 700;
  }

  .headerActions,
  .heroActions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .button {
    min-height: 46px;
    padding: 0 20px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 14px;
  }

  .button.large {
    min-height: 58px;
    padding: 0 28px;
    font-size: 15px;
  }

  .primary {
    background: var(--red);
    color: white;
    box-shadow: 0 14px 30px rgba(227, 6, 19, 0.2);
  }

  .cta {
  background: #f3d7d7;
  color: #c43c3c;
}

  .secondary {
    background: white;
    color: var(--red);
    border: 2px solid var(--red);
  }

  .hero {
    min-height: calc(100vh - 84px);
    padding: clamp(56px, 8vw, 110px) clamp(24px, 6vw, 88px);
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(40px, 6vw, 90px);
    align-items: center;
    background:
      radial-gradient(circle at top right, rgba(0,0,0,0.03), transparent 28%),
      linear-gradient(180deg, #ffffff 0%, #f4f5f7 100%);
  }

  .heroContent {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--red);
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 780px;
    font-size: clamp(46px, 6vw, 82px);
    line-height: 0.95;
    letter-spacing: -0.055em;
    color: var(--heading);
  }

  h2 {
    margin: 0;
    font-size: clamp(36px, 5vw, 62px);
    line-height: 1;
    letter-spacing: -0.045em;
    color: var(--heading);
  }

  .lead {
    margin: 28px 0 0;
    max-width: 650px;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
  }

  .heroActions {
    margin-top: 36px;
  }

  .officeCard {
    margin-top: 34px;
    max-width: 560px;
    background: white;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 22px 24px;
    display: grid;
    gap: 6px;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.055);
  }

  .officeCard span {
    color: var(--muted);
    font-weight: 700;
  }

  .heroImage {
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(15, 23, 42, 0.12);
  }

  .heroImage img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .mapa {
    margin-top: 20px;
  }

  .mapa iframe {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
  }

  .btnMapa {
    display: inline-block;
    margin-top: 15px;
    padding: 12px 24px;
    background: var(--red);
    color: white;
    border-radius: 8px;
    font-weight: 600;
  }

  .products,
  .trust,
  .languages,
  .team {
    padding: clamp(64px, 8vw, 100px) clamp(24px, 6vw, 88px);
  }

  .sectionHeader {
    max-width: 880px;
  }

  .productGrid {
    margin-top: 42px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .productCard {
    min-height: 255px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 26px;
    padding: 34px 28px;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
  }

  .productCard:hover {
    transform: translateY(-4px);
    border-color: var(--red);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  }

  .productCard:hover .productIcon {
    transform: scale(1.08);
  }

  .productIcon {
    width: 56px;
    height: 56px;
    margin-bottom: 24px;
    display: block;
    transition: transform 0.25s ease;
  }

  .productCard h3 {
    margin: 0 0 14px;
    font-size: 24px;
    font-weight: 900;
    color: var(--heading);
  }

  .productCard p {
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.5;
    font-weight: 600;
  }

  .productLink {
    display: inline-block;
    margin-top: auto;
    padding-top: 24px;
    color: var(--red);
    font-weight: 900;
    font-size: 17px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .productLink:hover {
    color: var(--red-dark);
    transform: translateX(4px);
  }

  .trust {
    background: white;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.85fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
  }

  .trust > p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.7;
  }

  .team {
    background: #f4f5f7;
    display: grid;
    grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
  }

  .teamImage {
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 30px 70px rgba(15, 23, 42, 0.12);
  }

  .teamImage img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .teamContent p {
    margin: 28px 0 0;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
  }

  .teamCard {
    margin-top: 20px;
    background: white;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 18px 20px;
    display: grid;
    gap: 4px;
  }

  .teamCard strong {
    color: var(--heading);
    font-size: 18px;
  }

  .teamCard span {
    color: var(--muted);
    font-weight: 700;
  }

  .languageContent {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.45fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: end;
  }

  .languageText {
    margin: 28px 0 0;
    max-width: 680px;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
  }

  .languageGrid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .languageCard {
    min-width: 180px;
    background: white;
    border: 1px solid var(--line);
    color: var(--black);
    border-radius: 999px;
    padding: 14px 18px;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    font-weight: 900;
  }

  .languageInfo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .languageFlag {
    width: 28px;
    height: 20px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .languageCard strong {
    color: var(--red);
  }

  .languageCard:hover {
    border-color: var(--red);
    color: var(--red);
  }

  @media (max-width: 980px) {
    .siteHeader {
      height: auto;
      padding-top: 18px;
      padding-bottom: 18px;
      align-items: flex-start;
      flex-direction: column;
    }

    .hero,
    .trust,
    .team,
    .languageContent {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .heroImage {
      order: -1;
      height: 320px;
    }

    .productGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .languageGrid {
      margin-top: 28px;
    }
  }
  .languageSwitcher {
  display: flex;
  gap: 14px;
  margin-left: auto;
  margin-right: 24px;
}

.languageSwitcher a {
  text-decoration: none;
  color: #374151;
  font-weight: 600;
}

.languageSwitcher a.active {
  color: #d81e05;
  font-weight: 700;
}

  @media (max-width: 620px) {
    .brand {
      width: 100%;
    }

    .logoFrame {
      width: 116px;
      height: 34px;
    }

    .logoFrame img {
      width: 116px;
    }

    .brandText {
      font-size: 15px;
      white-space: normal;
    }

    .headerActions,
    .heroActions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .button {
      width: 100%;
    }

    h1 {
      letter-spacing: -0.04em;
    }

    .productGrid,
    .languageGrid {
      grid-template-columns: 1fr;
    }

    .heroImage {
      height: 260px;
      border-radius: 24px;
    }
  }
.reviews {
  padding: clamp(64px, 8vw, 100px) clamp(24px, 6vw, 88px);
  background: white;
  text-align: center;
}

.reviewsContent {
  max-width: 820px;
  margin: 0 auto;
}

.reviewStars {
  color: #fbbf24;
  font-size: 32px;
  letter-spacing: 5px;
  margin: 22px 0 14px;
}

.reviewText {
  color: var(--muted);
  font-size: clamp(18px, 2vw, 22px);
  line-height: 1.6;
  margin: 0 auto 28px;
  max-width: 680px;
}

.reviewButton {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54px;
  padding: 0 28px;
  border-radius: 999px;
  background: #f3d7d7;
  color: #c43c3c;
  font-weight: 900;
  text-decoration: none;
}

.reviewButton:hover {
  background: #ebc8c8;
}
</style>