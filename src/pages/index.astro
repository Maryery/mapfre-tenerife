---
const phone = "+34 822 145 513 ";
const phoneHref = "tel:+34822145513";
const whatsappHref = "https://wa.me/34646743707";

const products = [
  {
    title: "Coche",
    text: "Protección para tu vehículo.",
    icon: "/icons/car.svg"
  },
  {
    title: "Hogar",
    text: "Tu vivienda siempre protegida.",
    icon: "/icons/home.svg"
  },
  {
    title: "Salud",
    text: "Acceso a medicina privada.",
    icon: "/icons/health.svg"
  },
  {
    title: "Vida",
    text: "Tranquilidad para tu familia.",
    icon: "/icons/heart.svg"
  },
  {
    title: "Ahorro e inversión",
    text: "Soluciones para tu futuro.",
    icon: "/icons/chart.svg"
  },
  {
    title: "Embarcaciones",
    text: "Navega con tranquilidad.",
    icon: "/icons/boat.svg"
  },
  {
    title: "Empresas",
    text: "Seguros para negocios y autónomos.",
    icon: "/icons/building.svg"
  },
  {
    title: "Decesos",
    text: "Todo organizado para tu familia.",
    icon: "/icons/shield.svg"
  }
];

const languages = [
{ label: "English", href: "/en/car-insurance-tenerife" },
{ label: "Deutsch", href: "/de/autoversicherung-teneriffa" },
{ label: "Italiano", href: "/it/assicurazione-auto-tenerife" },
{ label: "Russian", href: "/ru/strahovka-avto-tenerife" },
];
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Oficina MAPFRE Adeje | Seguros en Tenerife</title>
  <meta
          name="description"
          content="Oficina MAPFRE Adeje. Seguros en Tenerife para particulares, familias, empresas y clientes internacionales."
  />
</head>

<body>
<header class="siteHeader">
  <a href="/" class="brand" aria-label="MAPFRE Adeje">
        <span class="logoFrame">
          <img src="/logos/mapfre.svg" alt="MAPFRE" />
        </span>
        <span class="brandText"> <small>TENERIFE</small>Oficina Delegada ADEJE CALLE GRANDE
        </span>
  </a>

  <nav class="headerActions">
    <a href={phoneHref} class="button cta"> Contacto {phone}</a>
    <a href={whatsappHref} class="button secondary">WhatsApp</a>
  </nav>
</header>

<main>
  <section class="hero">
    <div class="heroContent">
      <p class="eyebrow">TU OFICINA MAPFRE EN ADEJE</p>

      <h1>Tu oficina MAPFRE de confianza en Adeje</h1>

      <p class="lead">
        Protegemos a familias, autónomos, comercios y empresas con soluciones de coche, hogar, salud, vida, decesos, ahorro e inversión.
      </p>

      <div class="heroActions">
        <a href={phoneHref} class="button primary large">Llámanos ahora</a>
        <a href={whatsappHref} class="button secondary large">Escríbenos por WhatsApp</a>
      </div>

      <div class="officeCard">
        <strong>Delegado/a:</strong>
        <span>Antonio Soto Melchor</span>
        <strong>Dirección:</strong>
        <span>Calle Grande, 56. 38670 - Adeje</span>
        <span>Santa Cruz de Tenerife · Atención presencial y multilingue</span>
        <strong>Horario de atención:</strong>
        <span>L - J 9:00 - 19:00</span>
        <span>V 9:00 - 17:00</span>

        <div class="mapa">
  <iframe
    src="https://www.google.com/maps?q=Calle+Grande+56+Adeje&output=embed"
    width="100%"
    height="350"
    style="border:0;border-radius:12px;"
    loading="lazy"
    allowfullscreen="">
  </iframe>
  <a
  href="https://maps.google.com/?q=Calle+Grande+56+Adeje"
  target="_blank"
  class="btnMapa">
  Cómo llegar
</a>
</div>
        
      </div>
    </div>

    <div class="heroImage">
      <img src="/images/hero.jpg" alt="Vida en Tenerife" />
    </div>
  </section>

  <section class="products">
  <div class="sectionHeader">
    <p class="eyebrow">Nuestros seguros</p>
    <h2>Tu oficina de confianza para todos tus seguros</h2>
  </div>

  <div class="productGrid">
    {products.map((product) => (
      <article class="productCard">

  <img
    src={product.icon}
    alt={product.title}
    class="productIcon"
  />

  <h3>{product.title}</h3>

  <p>{product.text}</p>

  <a
    href={`https://wa.me/34646743707?text=${encodeURIComponent(
      `Hola, quiero información sobre el seguro de ${product.title} con MAPFRE Adeje - Calle Grande 56.`
    )}`}
    target="_blank"
    class="productLink"
  >
    Solicitar presupuesto →
  </a>

</article>
    ))}
  </div>
</section>

  <section class="trust">
    <div>
      <p class="eyebrow">Experiencia y cercanía</p>
      <h2>Asesoramiento con criterio, compromiso y conocimiento local</h2>
    </div>

    <p>
      Contamos con años de experiencia en el sector asegurador y con el respaldo
      de MAPFRE. Nuestro objetivo es orientarte de forma clara, cercana y profesional
      para que puedas tomar una buena decisión.
    </p>
  </section>

  <section class="languages">
    <div class="sectionHeader">
      <p class="eyebrow">Atención internacional</p>
      <h2>También atendemos a clientes extranjeros en Tenerife</h2>
    </div>

    <div class="languageGrid">
      {languages.map((language) => (
      <a href={language.href} class="languageCard">
        <span>{language.label}</span>
        <strong>→</strong>
      </a>
      ))}
    </div>
  </section>
</main>
</body>
</html>

<style>
  :root {
    --red: #e30613;
    --red-dark: #c90012;
    --muted: #65707c;
    --bg: #f5f5f5;
    --white: #ffffff;
    --line: #e9e9e9;
    --radius-lg: 32px;
    --radius-md: 22px;
    --container: 1180px;
    --black: #1f2937;
    --text: #4b5563;
    --heading: #202938
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: var(--bg);
    color: var(--black);
  }

  a {
    text-decoration: none;
  }

  .siteHeader {
    height: 84px;
    padding: 0 clamp(24px, 6vw, 88px);
    background: var(--white);
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
    color: var(--black);
    font-weight: 900;
  }

  .logoFrame {
    width: 132px;
    height: 100px;
    display: flex;
    align-items: center;
    overflow: hidden;
    flex: 0 0 auto;
    padding: 5px;
  }

  .logoFrame img {
    width: 132px;
    height: auto;
    display: block;
  }


  .brandText {
    border-left: 1px solid #e7e7e7;

    padding-left: 22px;
    margin-left: 6px;

    display: flex;
    flex-direction: column;

    line-height: 1.05;

    white-space: nowrap;
  }

  .brandText small {
    font-size: 11px;

    text-transform: uppercase;
    letter-spacing: .12em;

    color: #9aa3af;

    font-weight: 700;
  }


  .brandText strong {
    margin-top: 4px;

    font-size: 28px;
    letter-spacing: -0.04em;

    color: #1f2937;

    font-weight: 800;
  }

  .headerActions,
  .heroActions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .button {
    min-height: 46px;
    padding: 0 20px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 14px;
  }

  .button.large {
    min-height: 58px;
    padding: 0 28px;
    font-size: 15px;
  }

  .primary {
    background: var(--red);
    color: white;
    box-shadow: 0 14px 30px rgba(227, 6, 19, 0.2);
  }

  .cta {
    background: green;
    color: white;
  }



  .secondary {
    background: white;
    color: var(--red);
    border: 2px solid var(--red);
  }

  .hero {
    min-height: calc(100vh - 84px);
    padding: clamp(56px, 8vw, 110px) clamp(24px, 6vw, 88px);

    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(40px, 6vw, 90px);

    align-items: center;

    background:
            radial-gradient(
                    circle at top right,
                    rgba(0,0,0,0.03),
                    transparent 28%
            ),
            linear-gradient(
                    180deg,
                    #ffffff 0%,
                    #f4f5f7 100%
            );
  }

  .heroContent {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--red);
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 780px;
    font-size: clamp(46px, 6vw, 82px);
    line-height: 0.95;
    letter-spacing: -0.055em;
    color: var(--heading);
  }


  .lead {
    margin: 28px 0 0;
    max-width: 650px;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
  }

  .heroActions {
    margin-top: 36px;
  }

  .officeCard {
    margin-top: 34px;
    max-width: 560px;
    background: white;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 22px 24px;
    display: grid;
    gap: 6px;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.055);
  }

  .officeCard span {
    color: var(--muted);
    font-weight: 700;
  }

  .heroImage {
    box-shadow:
            0 40px 80px rgba(15, 23, 42, 0.12);
  }


  .heroImage img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .products,
  .trust,
  .languages {
    padding: clamp(64px, 8vw, 100px) clamp(24px, 6vw, 88px);
  }

  .sectionHeader {
    max-width: 880px;
  }

  h2 {
    margin: 0;
    font-size: clamp(36px, 5vw, 62px);
    line-height: 1;
    letter-spacing: -0.045em;
    color: var(--heading);
  }

  .productGrid {
  margin-top: 42px;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 22px;
}

.productCard {
  min-height: 255px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 26px;
  padding: 34px 28px;
  display: flex;
  flex-direction: column;
  transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  cursor: pointer;
}

.productCard:hover {
  transform: translateY(-4px);
  border-color: var(--red);
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
}

.productCard:hover .productIcon {
  transform: scale(1.08);
}

.productIcon {
  width: 56px;
  height: 56px;
  margin-bottom: 24px;
  color: var(--red);
  display: block;
  transition: transform 0.25s ease;
}

.productIcon svg,
.productIcon svg * {
  width: 56px;
  height: 56px;
  display: block;
  stroke: var(--red) !important;
  fill: none !important;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.productCard h3 {
  margin: 0 0 14px;
  font-size: 24px;
  font-weight: 900;
  color: var(--heading);
}

.productCard p {
  margin: 0;
  color: var(--muted);
  font-size: 16px;
  line-height: 1.5;
  font-weight: 600;
}

.productLink {
  display: inline-block;
  margin-top: auto;
  padding-top: 24px;
  color: var(--red);
  font-weight: 900;
  font-size: 17px;
  text-decoration: none;
  transition: all 0.2s ease;
}

.productLink:hover {
  color: var(--red-dark);
  transform: translateX(4px);
}

  .trust {
    background: white;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.85fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
  }

  .trust > p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.7;
  }

  .languageGrid {
    margin-top: 38px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .languageCard {
    min-width: 150px;
    background: white;
    border: 1px solid var(--line);
    color: var(--black);
    border-radius: 999px;
    padding: 16px 20px;
    display: inline-flex;
    justify-content: space-between;
    gap: 18px;
    font-weight: 900;
  }

  .languageCard strong {
    color: var(--red);
  }

  @media (max-width: 980px) {
    .siteHeader {
      height: auto;
      padding-top: 18px;
      padding-bottom: 18px;
      align-items: flex-start;
      flex-direction: column;
    }

    .hero {
      min-height: auto;
      grid-template-columns: 1fr;
    }

    .heroImage {
      order: -1;
      height: 320px;
    }

    .productGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .trust {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .brand {
      width: 100%;
    }

    .logoFrame {
      width: 116px;
      height: 34px;
    }

    .logoFrame img {
      width: 116px;
    }

    .brandText {
      font-size: 15px;
      white-space: normal;
    }

    .headerActions,
    .heroActions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .button {
      width: 100%;
    }

    h1 {
      letter-spacing: -0.04em;
    }

    .productGrid {
      grid-template-columns: 1fr;
    }

    .heroImage {
      height: 260px;
      border-radius: 24px;
    }
  }
  .mapa {
  margin-top: 20px;
}

.mapa iframe {
  width: 100%;
  border-radius: 12px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.15);
}
.btnMapa{
  display:inline-block;
  margin-top:15px;
  padding:12px 24px;
  background:#d81e05;
  color:white;
  text-decoration:none;
  border-radius:8px;
  font-weight:600;
}
</style>