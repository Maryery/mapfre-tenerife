<style>
  :global(body) {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f5f5f5;
    color: #111;
  }

  .home {
    min-height: 100vh;
    padding: 60px 7vw;
  }

  .hero {
    background: white;
    border-radius: 32px;
    padding: 50px;
    margin-bottom: 30px;
    border-top: 8px solid #c40018;
    box-shadow: 0 20px 60px rgba(0, 0, 0, .06);
  }

  .hero p {
    color: #c40018;
    font-weight: 800;
    margin: 0 0 10px;
  }

  .hero h1 {
    font-size: 54px;
    margin: 0 0 14px;
    letter-spacing: -2px;
  }

  .hero span {
    color: #555;
    font-weight: 700;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .grid div {
    background: white;
    padding: 28px;
    border-radius: 24px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, .04);
  }

  h2 {
    margin-top: 0;
    color: #c40018;
  }

  a {
    display: block;
    padding: 12px 0;
    color: #111;
    text-decoration: none;
    font-weight: 700;
    border-bottom: 1px solid #eee;
  }

  a:hover {
    color: #c40018;
  }

  @media(max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 32px;
    }

    .hero h1 {
      font-size: 38px;
    }
  }
</style>