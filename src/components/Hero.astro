---
const { title, subtitle, cta = "Contactar por WhatsApp" } = Astro.props;
---

<section style="font-family: system-ui; padding: 80px 24px; text-align: center; max-width: 900px; margin: auto;">
  <p style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px;">
    Seguros en Tenerife
  </p>

  <h1 style="font-size: 48px; line-height: 1.1; margin: 16px 0;">
    {title}
  </h1>

  <p style="font-size: 20px; color: #555; max-width: 650px; margin: 0 auto 32px;">
    {subtitle}
  </p>

  <a
    href="https://wa.me/34600000000"
    style="background: #16a34a; color: white; padding: 14px 24px; border-radius: 999px; text-decoration: none; font-weight: 700;"
  >
    {cta}
  </a>
</section>