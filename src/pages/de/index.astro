---
const phone = "+34 822 145 513";
const phoneHref = "tel:+34822145513";
const whatsappHref = "https://wa.me/34646743707?text=Hallo%2C%20ich%20m%C3%B6chte%20Informationen%20%C3%BCber%20die%20Versicherungen%20von%20MAPFRE%20in%20Adeje%20erhalten.";

const products = [
  { title: "Auto", text: "Schutz für Ihr Fahrzeug.", icon: "/icons/car.svg" },
  { title: "Haus", text: "Ihr Zuhause immer gut geschützt.", icon: "/icons/home.svg" },
  { title: "Gesundheit", text: "Zugang zu privater Gesundheitsversorgung.", icon: "/icons/health.svg" },
  { title: "Leben", text: "Sicherheit für Ihre Familie.", icon: "/icons/heart.svg" },
  { title: "Sparen und Investition", text: "Lösungen für Ihre Zukunft.", icon: "/icons/chart.svg" },
  { title: "Boote", text: "Mit Ruhe und Sicherheit unterwegs.", icon: "/icons/boat.svg" },
  { title: "Unternehmen", text: "Versicherungen für Geschäfte und Selbstständige.", icon: "/icons/building.svg" },
  { title: "Bestattungsvorsorge", text: "Alles organisiert für Ihre Familie.", icon: "/icons/shield.svg" },
];

const languages = [
  { flag: "/flags/gb.svg", label: "English", href: "/en/" },
  { flag: "/flags/de.svg", label: "Deutsch", href: "/de/" },
  { flag: "/flags/it.svg", label: "Italiano", href: "/it/" },
  { flag: "/flags/fr.svg", label: "Français", href: "/fr/" },
];
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>MAPFRE Adeje Büro | Versicherungen auf Teneriffa</title>
  <link rel="icon" href="/logos/mapfre.svg" type="image/svg+xml" />
  <meta
    name="description"
    content="MAPFRE Adeje Büro. Versicherungen auf Teneriffa für Familien, Residenten, Selbstständige, Geschäfte und Unternehmen."
  />
</head>

<body>
<header class="siteHeader">
  <a href="/" class="brand" aria-label="MAPFRE Adeje">
    <span class="logoFrame">
      <img src="/logos/mapfre.svg" alt="MAPFRE" />
    </span>
    <span class="brandText">
      <small>TENERIFE</small>
      MAPFRE Büro ADEJE CALLE GRANDE
    </span>
  </a>
  <nav class="languageSwitcher">
    <a href="/">ES</a>
    <a href="/en/">EN</a>
    <a href="/de/" class="active">DE</a>
    <a href="/it/">IT</a>
    <a href="/fr/">FR</a>
  </nav>
  <nav class="headerActions">
    <a href={phoneHref} class="button cta">Kontakt {phone}</a>
    <a href={whatsappHref} class="button secondary">WhatsApp</a>
  </nav>
</header>

<main>
  <section class="hero">
    <div class="heroContent">
      <p class="eyebrow">Ihr MAPFRE Büro in Adeje</p>

      <h1>Ihr MAPFRE Büro des Vertrauens in Adeje</h1>

      <p class="lead">
        Persönliche Beratung und maßgeschneiderte Versicherungslösungen für Familien, Residenten, Selbstständige, Geschäfte und Unternehmen.
      </p>

      <div class="heroActions">
        <a href={phoneHref} class="button primary large">Jetzt anrufen</a>
        <a href={whatsappHref} class="button secondary large">Per WhatsApp schreiben</a>
      </div>

      <div class="officeCard">
        <strong>MAPFRE Adeje Team</strong>
        <span>Antonio Soto Melchor · Delegierter</span>
        <span>Maryery Vargas Moreno · Kundenberaterin</span>

        <strong>Adresse:</strong>
        <span>Calle Grande, 56. 38670 - Adeje</span>
        <span>Santa Cruz de Tenerife · Persönliche und mehrsprachige Betreuung</span>

        <strong>Öffnungszeiten:</strong>
        <span>Mo - Do 9:00 - 19:00</span>
        <span>Fr 9:00 - 17:00</span>

        <div class="mapa">
          <iframe
            src="https://www.google.com/maps?q=Calle+Grande+56+Adeje&output=embed"
            width="100%"
            height="350"
            style="border:0;border-radius:12px;"
            loading="lazy"
            allowfullscreen="">
          </iframe>

          <a
            href="https://maps.google.com/?q=Calle+Grande+56+Adeje"
            target="_blank"
            class="btnMapa">
            Anfahrt anzeigen
          </a>
        </div>
      </div>
    </div>

    <div class="heroImage">
      <img src="/images/antonio.png" alt="Antonio Soto Melchor, Delegierter von MAPFRE Adeje" />
    </div>
  </section>

  <section class="products">
    <div class="sectionHeader">
      <p class="eyebrow">Unsere Versicherungen</p>
      <h2>Ihr Büro des Vertrauens für alle Ihre Versicherungen</h2>
    </div>

    <div class="productGrid">
      {products.map((product) => (
        <article class="productCard">
          <img src={product.icon} alt={product.title} class="productIcon" />

          <h3>{product.title}</h3>

          <p>{product.text}</p>

          <a
            href={`https://wa.me/34646743707?text=${encodeURIComponent(
              `Hallo, ich möchte Informationen über die Versicherung ${product.title} bei MAPFRE Adeje - Calle Grande 56.`
            )}`}
            target="_blank"
            class="productLink"
          >
            Angebot anfordern →
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="trust">
    <div>
      <p class="eyebrow">Erfahrung und Nähe</p>
      <h2>Beratung mit Kompetenz, Engagement und lokaler Erfahrung</h2>
    </div>

    <p>
      Wir sind kein Vergleichsportal und kein Callcenter. Wir sind ein persönliches Büro in Adeje, in dem wir Sie individuell beraten und Ihnen helfen, die Versicherung zu wählen, die Sie wirklich brauchen. Wir analysieren Ihre Situation, beantworten Ihre Fragen und begleiten Sie, wenn Sie uns am meisten benötigen.
    </p>
  </section>

  <section class="team">
    <div class="teamImage">
      <img src="/images/maryery.JPG" alt="Maryery Vargas Moreno, Kundenberaterin bei MAPFRE Adeje" />
    </div>

    <div class="teamContent">
      <p class="eyebrow">Persönliche Betreuung</p>
      <h2>Lernen Sie Ihr MAPFRE Adeje Team kennen</h2>

      <p>
        Wir beraten Sie klar, freundlich und professionell, damit Sie die Versicherungslösung finden, die am besten zu Ihren Bedürfnissen passt.
      </p>

      <div class="teamCard">
        <strong>Maryery Vargas Moreno</strong>
        <span>Kundenberaterin · MAPFRE Adeje</span>
      </div>

      <div class="teamCard">
        <strong>Antonio Soto Melchor</strong>
        <span>Delegierter · MAPFRE Adeje</span>
      </div>
    </div>
  </section>
  <section class="reviews">
  <div class="reviewsContent">
    <p class="eyebrow">Kundenbewertungen</p>

    <h2>Das Vertrauen unserer Kunden spricht für sich</h2>

    <div class="reviewStars">★★★★★</div>

    <p class="reviewText">
      Lesen Sie die Erfahrungen unserer Kunden mit dem Service, der persönlichen Beratung und der Betreuung von MAPFRE Adeje.
    </p>

    <a
      href="https://www.google.com/search?q=mapfre+adeje+calle+grande"
      target="_blank"
      rel="noopener noreferrer"
      class="reviewButton"
    >
      Google-Bewertungen lesen
    </a>
  </div>
</section>
  <section class="languages">
    <div class="languageContent">
      <div>
        <p class="eyebrow">Mehrsprachige Betreuung</p>

        <h2>Wir betreuen ausländische Residenten und Immobilienbesitzer auf Teneriffa</h2>

        <p class="languageText">
          Wir helfen Ihnen, Ihre Versicherungen in Ihrer Sprache abzuschließen und zu verwalten, mit persönlicher und freundlicher Betreuung in unserem Büro in Adeje.
        </p>
      </div>

      <div class="languageGrid">
        {languages.map((language) => (
          <a href={language.href} class="languageCard">
            <span class="languageInfo">
              <img src={language.flag} alt={language.label} class="languageFlag" />
              <span>{language.label}</span>
            </span>
            <strong>→</strong>
          </a>
        ))}
      </div>
    </div>
  </section>
</main>
</body>
</html>

<style>
  :root {
    --red: #e30613;
    --red-dark: #c90012;
    --muted: #65707c;
    --bg: #f5f5f5;
    --white: #ffffff;
    --line: #e9e9e9;
    --radius-md: 22px;
    --black: #1f2937;
    --text: #4b5563;
    --heading: #202938;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: var(--bg);
    color: var(--black);
  }

  a {
    text-decoration: none;
  }

  .siteHeader {
    height: 84px;
    padding: 0 clamp(24px, 6vw, 88px);
    background: var(--white);
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
    color: var(--black);
    font-weight: 900;
  }

  .logoFrame {
    width: 132px;
    height: 100px;
    display: flex;
    align-items: center;
    overflow: hidden;
    flex: 0 0 auto;
    padding: 5px;
  }

  .logoFrame img {
    width: 132px;
    height: auto;
    display: block;
  }

  .brandText {
    border-left: 1px solid #e7e7e7;
    padding-left: 22px;
    margin-left: 6px;
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    white-space: nowrap;
  }

  .brandText small {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: #9aa3af;
    font-weight: 700;
  }

  .headerActions,
  .heroActions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .button {
    min-height: 46px;
    padding: 0 20px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 14px;
  }

  .button.large {
    min-height: 58px;
    padding: 0 28px;
    font-size: 15px;
  }

  .primary {
    background: var(--red);
    color: white;
    box-shadow: 0 14px 30px rgba(227, 6, 19, 0.2);
  }

  .cta {
    background: #f3d7d7;
    color: #c43c3c;
  }

  .secondary {
    background: white;
    color: var(--red);
    border: 2px solid var(--red);
  }

  .hero {
    min-height: calc(100vh - 84px);
    padding: clamp(56px, 8vw, 110px) clamp(24px, 6vw, 88px);
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(40px, 6vw, 90px);
    align-items: center;
    background:
      radial-gradient(circle at top right, rgba(0,0,0,0.03), transparent 28%),
      linear-gradient(180deg, #ffffff 0%, #f4f5f7 100%);
  }

  .heroContent {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--red);
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 780px;
    font-size: clamp(46px, 6vw, 82px);
    line-height: 0.95;
    letter-spacing: -0.055em;
    color: var(--heading);
  }

  h2 {
    margin: 0;
    font-size: clamp(36px, 5vw, 62px);
    line-height: 1;
    letter-spacing: -0.045em;
    color: var(--heading);
  }

  .lead {
    margin: 28px 0 0;
    max-width: 650px;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
  }

  .heroActions {
    margin-top: 36px;
  }

  .officeCard {
    margin-top: 34px;
    max-width: 560px;
    background: white;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 22px 24px;
    display: grid;
    gap: 6px;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.055);
  }

  .officeCard span {
    color: var(--muted);
    font-weight: 700;
  }

  .heroImage {
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(15, 23, 42, 0.12);
  }

  .heroImage img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .mapa {
    margin-top: 20px;
  }

  .mapa iframe {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
  }

  .btnMapa {
    display: inline-block;
    margin-top: 15px;
    padding: 12px 24px;
    background: var(--red);
    color: white;
    border-radius: 8px;
    font-weight: 600;
  }

  .products,
  .trust,
  .languages,
  .team {
    padding: clamp(64px, 8vw, 100px) clamp(24px, 6vw, 88px);
  }

  .sectionHeader {
    max-width: 880px;
  }

  .productGrid {
    margin-top: 42px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .productCard {
    min-height: 255px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 26px;
    padding: 34px 28px;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
  }

  .productCard:hover {
    transform: translateY(-4px);
    border-color: var(--red);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  }

  .productCard:hover .productIcon {
    transform: scale(1.08);
  }

  .productIcon {
    width: 56px;
    height: 56px;
    margin-bottom: 24px;
    display: block;
    transition: transform 0.25s ease;
  }

  .productCard h3 {
    margin: 0 0 14px;
    font-size: 24px;
    font-weight: 900;
    color: var(--heading);
  }

  .productCard p {
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.5;
    font-weight: 600;
  }

  .productLink {
    display: inline-block;
    margin-top: auto;
    padding-top: 24px;
    color: var(--red);
    font-weight: 900;
    font-size: 17px;
    transition: all 0.2s ease;
  }

  .productLink:hover {
    color: var(--red-dark);
    transform: translateX(4px);
  }

  .trust {
    background: white;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.85fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
  }

  .trust > p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.7;
  }

  .team {
    background: #f4f5f7;
    display: grid;
    grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
  }

  .teamImage {
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 30px 70px rgba(15, 23, 42, 0.12);
  }

  .teamImage img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .teamContent p {
    margin: 28px 0 0;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
  }

  .teamCard {
    margin-top: 20px;
    background: white;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 18px 20px;
    display: grid;
    gap: 4px;
  }

  .teamCard strong {
    color: var(--heading);
    font-size: 18px;
  }

  .teamCard span {
    color: var(--muted);
    font-weight: 700;
  }

  .languageContent {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.45fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: end;
  }

  .languageText {
    margin: 28px 0 0;
    max-width: 680px;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
  }

  .languageGrid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .languageCard {
    min-width: 180px;
    background: white;
    border: 1px solid var(--line);
    color: var(--black);
    border-radius: 999px;
    padding: 14px 18px;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    font-weight: 900;
  }

  .languageInfo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .languageFlag {
    width: 28px;
    height: 20px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .languageCard strong {
    color: var(--red);
  }

  .languageCard:hover {
    border-color: var(--red);
    color: var(--red);
  }

  @media (max-width: 980px) {
    .siteHeader {
      height: auto;
      padding-top: 18px;
      padding-bottom: 18px;
      align-items: flex-start;
      flex-direction: column;
    }

    .hero,
    .trust,
    .team,
    .languageContent {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .heroImage {
      order: -1;
      height: 320px;
    }

    .productGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .languageGrid {
      margin-top: 28px;
    }
  }
  .languageSwitcher {
  display: flex;
  gap: 14px;
  margin-left: auto;
  margin-right: 24px;
}

.languageSwitcher a {
  text-decoration: none;
  color: #374151;
  font-weight: 600;
}

.languageSwitcher a.active {
  color: #d81e05;
  font-weight: 700;
}

  @media (max-width: 620px) {
    .brand {
      width: 100%;
    }

    .logoFrame {
      width: 116px;
      height: 34px;
    }

    .logoFrame img {
      width: 116px;
    }

    .brandText {
      font-size: 15px;
      white-space: normal;
    }

    .headerActions,
    .heroActions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .button {
      width: 100%;
    }

    h1 {
      letter-spacing: -0.04em;
    }

    .productGrid,
    .languageGrid {
      grid-template-columns: 1fr;
    }

    .heroImage {
      height: 260px;
      border-radius: 24px;
    }
  }
.reviews {
  padding: clamp(64px, 8vw, 100px) clamp(24px, 6vw, 88px);
  background: white;
  text-align: center;
}

.reviewsContent {
  max-width: 820px;
  margin: 0 auto;
}

.reviewStars {
  color: #fbbf24;
  font-size: 32px;
  letter-spacing: 5px;
  margin: 22px 0 14px;
}

.reviewText {
  color: var(--muted);
  font-size: clamp(18px, 2vw, 22px);
  line-height: 1.6;
  margin: 0 auto 28px;
  max-width: 680px;
}

.reviewButton {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54px;
  padding: 0 28px;
  border-radius: 999px;
  background: #f3d7d7;
  color: #c43c3c;
  font-weight: 900;
  text-decoration: none;
}

.reviewButton:hover {
  background: #ebc8c8;
}
</style>